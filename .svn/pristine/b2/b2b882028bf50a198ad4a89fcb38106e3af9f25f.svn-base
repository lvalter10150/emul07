CC       = gcc
#CFLAGS  = -O2 -DLSB_FIRST -DDEBUG
#CFLAGS  = -O2 -DMSB_FIRST -DDEBUG -g -Wall -Wbuiltin-declaration-mismatch -Wimplicit-function-declaration -Wunused-but-set-variable -I/usr/include/SDL2 -D_REENTRANT -lSDL2 -Wmisleading-indentation -Wunused-variable
#CFLAGS   = -g -O2 -DMSB_FIRST -DDEBUG -g -Wall
#CFLAGS   = -g -O2 -DMSB_FIRST -g -Wall
CFLAGS   = -g -O2 -DLSB_FIRST -g -Wall
OBJ = Z80.o Debug.o x07.o T6834.o video.o sound.o

x07:$(OBJ)
	gcc -O2 -Wall -Wextra -o x07cas wav2cas_x07.c
	gcc $(CFLAGS) -o x07 -O $(OBJ) -lSDL2 -lm

Z80.o:	Z80.c Z80.h Codes.h CodesED.h CodesCB.h CodesXX.h Tables.h CodesXCB.h
	gcc $(CFLAGS) -c -O Z80.c

Debug.o:Debug.c Z80.h
	gcc $(CFLAGS) -c -O Debug.c

x07.o:x07.c Z80.h Tables.h var.h struct.h const.h proto.h video.c
	gcc $(CFLAGS) -c -O x07.c

T6834.o:T6834.c Z80.h Tables.h var.h struct.h const.h proto.h
	gcc $(CFLAGS) -c -O T6834.c

video.o:T6834.c Z80.h Tables.h var.h struct.h const.h proto.h video.c
	gcc $(CFLAGS) -c -O video.c $(inc_X11)

lit_ini.o:lit_ini.c
	gcc $(CFLAGS) -c -O lit_ini.c

sound.o:sound.c
	gcc $(CFLAGS) -c -O sound.c

dasm:	dasm.c
	gcc -o dasm dasm.c

clean:
	rm *.o x07
	
archive:
	tar cvzf ../canonX07.tar.gz *
