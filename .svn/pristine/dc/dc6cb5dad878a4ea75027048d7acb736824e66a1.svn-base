#include <SDL2/SDL.h>
#include <stdio.h>
#include <stdint.h>

#define SOUND_SAMPLE_RATE 44100

/*
 * Réglages provisoires pour le BEEP BASIC du Canon X-07.
 *
 * Hypothèse actuelle :
 *   BEEP durée, fréquence
 *
 * Exemple :
 *   BEEP 10,1    -> durée 10, fréquence 1
 *   BEEP 10,100  -> même durée, fréquence différente
 *   BEEP 100,10  -> durée plus longue
 */
#define X07_BEEP_DURATION_UNIT_MS 20

static SDL_AudioDeviceID audio_dev = 0;
static int sound_initialized = 0;

typedef struct {
    int active;
    int freq_hz;
    int samples_left;
    double phase;
} BuzzerState;

static BuzzerState buzzer = {0, 0, 0, 0.0};

/*
 * Génération audio SDL.
 * On génère une onde carrée, plus proche d'un buzzer
 * qu'une sinusoïde.
 */
static void audio_callback(void *userdata, Uint8 *stream, int len)
{
    Sint16 *buffer = (Sint16 *)stream;
    int samples = len / sizeof(Sint16);

    (void)userdata;

    for (int i = 0; i < samples; i++) {
        if (buzzer.active && buzzer.freq_hz > 0) {
            Sint16 sample;

            if (buzzer.phase < 0.5)
                sample = 5000;
            else
                sample = -5000;

            buffer[i] = sample;

            buzzer.phase += (double)buzzer.freq_hz / (double)SOUND_SAMPLE_RATE;
            if (buzzer.phase >= 1.0)
                buzzer.phase -= 1.0;

            if (buzzer.samples_left > 0) {
                buzzer.samples_left--;

                if (buzzer.samples_left <= 0) {
                    buzzer.active = 0;
                    buzzer.freq_hz = 0;
                    buzzer.phase = 0.0;
                }
            }
        } else {
            buffer[i] = 0;
        }
    }
}

void Sound_Init(void)
{
    SDL_AudioSpec want;

    if (sound_initialized)
        return;

    if (SDL_InitSubSystem(SDL_INIT_AUDIO) != 0) {
        fprintf(stderr, "[SOUND] SDL_InitSubSystem error: %s\n", SDL_GetError());
        return;
    }

    SDL_zero(want);
    want.freq = SOUND_SAMPLE_RATE;
    want.format = AUDIO_S16SYS;
    want.channels = 1;
    want.samples = 1024;
    want.callback = audio_callback;

    audio_dev = SDL_OpenAudioDevice(NULL, 0, &want, NULL, 0);
    if (!audio_dev) {
        fprintf(stderr, "[SOUND] SDL_OpenAudioDevice error: %s\n", SDL_GetError());
        return;
    }

    SDL_PauseAudioDevice(audio_dev, 0);
    sound_initialized = 1;

    fprintf(stderr, "[SOUND] initialized\n");
}

void Sound_Close(void)
{
    if (audio_dev) {
        SDL_CloseAudioDevice(audio_dev);
        audio_dev = 0;
    }

    if (sound_initialized) {
        SDL_QuitSubSystem(SDL_INIT_AUDIO);
        sound_initialized = 0;
    }
}

void Sound_Beep(int freq_hz, int duration_ms)
{
    if (freq_hz <= 0 || duration_ms <= 0)
        return;

    if (!sound_initialized)
        Sound_Init();

    if (!sound_initialized)
        return;

    SDL_LockAudioDevice(audio_dev);

    buzzer.active = 1;
    buzzer.freq_hz = freq_hz;
    buzzer.samples_left = SOUND_SAMPLE_RATE * duration_ms / 1000;
    buzzer.phase = 0.0;

    SDL_UnlockAudioDevice(audio_dev);
}

/*
 * Conversion provisoire du deuxième paramètre BASIC
 * vers une fréquence audible.
 *
 * freq_x07 = 1   -> grave
 * freq_x07 = 100 -> plus aigu
 */
int Sound_X07_Param_To_Freq(uint8_t freq_x07)
{
    int freq_hz;

    if (freq_x07 == 0)
        return 0;

    /*
     * Mapping provisoire simple.
     * On l'ajustera ensuite si on retrouve la vraie table ROM.
     */
    freq_hz = 80 + ((int)freq_x07 * 25);

    if (freq_hz < 50)
        freq_hz = 50;

    if (freq_hz > 8000)
        freq_hz = 8000;

    return freq_hz;
}

/*
 * Conversion provisoire du premier paramètre BASIC
 * vers une durée en millisecondes.
 */
int Sound_X07_Param_To_Duration(uint8_t duration_x07)
{
    int duration_ms;

    if (duration_x07 == 0)
        return 0;

    duration_ms = (int)duration_x07 * X07_BEEP_DURATION_UNIT_MS;

    if (duration_ms < 10)
        duration_ms = 10;

    if (duration_ms > 5000)
        duration_ms = 5000;

    return duration_ms;
}

/*
 * BEEP Canon X-07.
 *
 */
void Sound_Beep_X07(uint8_t duration_x07, uint8_t freq_x07)
{
    int freq_hz;
    int duration_ms;

    /*
     * Sécurité provisoire :
     * pour l'instant F2/F3 semblent parfois rester à 00.
     * Donc on force des valeurs audibles pour ne pas couper le son.
     */
    if (duration_x07 == 0)
        duration_x07 = 3;

    if (freq_x07 == 0)
        freq_x07 = 40;

    freq_hz = Sound_X07_Param_To_Freq(freq_x07);
    duration_ms = Sound_X07_Param_To_Duration(duration_x07);

    fprintf(stderr,
        "[SOUND X07] duration_x07=%u freq_x07=%u -> %d Hz, %d ms\n",
        duration_x07,
        freq_x07,
        freq_hz,
        duration_ms
    );
    fflush(stderr);

    Sound_Beep(freq_hz, duration_ms);
}
