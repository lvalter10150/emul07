/*

     CCCCCC       A       NNN     NN   OOOOOOOO   NNN     NN 
    CC          AA AA     NN N    NN  OO      OO  NN N    NN
    CC         AA   AA    NN  N   NN  OO      OO  NN  N   NN
    CC        AA    AA    NN   N  NN  OO      OO  NN   N  NN
    CC       AAAAAAAAAA   NN    N NN  OO      OO  NN    N NN
    CC       AA      AA   NN     NNN  OO      OO  NN     NNN
     CCCCCC  AA      AA   NN      NN   OOOOOOOO   NN      NN 

             XX      XX    OOOOOOOO   7777777777
              XX    XX    OO      OO         77
               XX  XX     OO      OO        77
                XXXX      OO      OO       77
               XX  XX     OO      OO      77
              XX    XX    OO      OO     77
             XX      XX    OOOOOOOO     77
           
*/
/*--------------------------------------------------------------------------*/

#include <unistd.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <signal.h>
#include <sys/time.h>
#include "Z80.h"

/*
           Mémoire du XO7
  0000    ----------------
         |  XXXX  |  RAM  |
  2000    ----------------
         | Carte RAM 8Ko  |
  4000    ----------------
         | Prise ROM 8Ko  |
  6000    ----------------
         | ROM Carte 8Ko  |
  8000    ----------------
         | V-RAM 6Ko      |
  9800    ----------------
         | ~~~~~~~~~~~~~~ |
  A000    ----------------
         | ROM TV 4Ko     |
  B000    ----------------
         | ROM 20Ko BASIC |
  FFFF    ----------------

*/

#define VAR_GLOB
#include "struct.h"
#include "const.h"
#include "var.h"
#include "proto.h"
#include "rom_xo7.h"

#define USE_ROM_TV 0
#define PATCH_MISSING_ROM_TV 1

#define X07_STATE_MAGIC     "X07ST01"
#define X07_STATE_MAGIC_LEN 7
#define X07_STATE_FILE      "/tmp/x07_state.bin"

static byte Power_Off    = 0;
static byte Mode_K7      = 0;
static byte Presence_k7  = 0; /* Une k7 est presente */
static FILE *Fichier_k7  = 0; /* Fichier de k7 */
//static char K7_Name[80];
static byte Sound_F4_Last = 0;
static int  Sound_Armed   = 0;

typedef struct {
	char magic[8];
	unsigned int taille_ram;

	Z80 Reg_Xo7_save;
	PorT_FX Port_FX_save;
	GENERAL_INFO General_Info_save;
	CLAVIER      Clavier_save;
	byte Tmp_save;
	byte IT_T6834_save;
	byte Int_nsc800_BB_save;
	byte Mode_K7_save;
	byte Power_Off_save;
} X07_State;

int main (void) {
	/* Initialisation des variables globales */
	/*---------------------------------------*/
	Tmp = 0;
	IT_T6834 = 0;
	int snapshot_ok = 0;
	/* Allocation de la memoire du XO7 */
	/*---------------------------------*/
	if (!(RAM= (byte *) malloc (Taille_Ram))) {
	   fprintf (stderr,"Allocation Memoire impossible!/n");
	   exit (1);
	}
	/* Effacementt de la memoire */
	/*---------------------------*/
	memset((void*)RAM, 0xFF, Taille_Ram);
	memset((void*)&Port_FX, 0, sizeof(Port_FX));
	memset((void*)&Clavier, 0, sizeof(Clavier));
	memset((void*)&General_Info, 0, sizeof(General_Info));
	
	snapshot_ok = (Load_Ram_Temp() == RC_OK);
	
	/* Mise en place des touches speciales */
	/*-------------------------------------*/
	signal (SIGINT, Active_Debugger); /* Ctrl C */
	signal (SIGTSTP, Active_Int);     /* Ctrl Z */

	if (!snapshot_ok) {
		/*
		 * Aucun snapshot trouvé :
		 * démarrage normal comme une machine froide.
		 */
		ResetZ80(&Reg_Xo7);

		Reg_Xo7.IPeriod = 100;
		Reg_Xo7.Trace   = 1;

		Int_nsc800_BB = 0;

		/*
		 * Point d'entrée ROM du Canon X-07.
		 */
		Reg_Xo7.PC.W = 0xC3C3;

		Init_Etat_Xo7();

		fprintf(stderr, "Démarrage normal PC=%04X\n", Reg_Xo7.PC.W);
	} else {
		/*
		 * Snapshot trouvé :
		 * surtout pas de ResetZ80()
		 * surtout pas de PC = 0xC3C3
		 * surtout pas de Init_Etat_Xo7()
		 */
		Reg_Xo7.IPeriod = 100;
		Reg_Xo7.Trace   = 0;

		fprintf(stderr, "Reprise snapshot PC=%04X\n", Reg_Xo7.PC.W);
	}
	/* Lancement de la fenetre X11 */
	/*-----------------------------*/
	iniscreen ();
	
	fprintf(stderr, "AVANT RunZ80 PC=%04X OP=%02X Power_Off=%d\n",
	        Reg_Xo7.PC.W,
	        RdZ80(Reg_Xo7.PC.W),
	        Power_Off);
	fflush(stderr);
	
	/*------------------------*/
	RunZ80(&Reg_Xo7);
	/* Liberation de la memoire */
	/*--------------------------*/
	free (RAM);
	/* Fin du programme */
	/*------------------*/
	return (0);
}

void Init_Etat_Xo7 (void)
{
	memset((void *)General_Info.F_Key, 0, sizeof(General_Info.F_Key));
	strncpy((char *)General_Info.F_Key[0],  "tim?TIME$\r", 80);  /* F1  */
	strncpy((char *)General_Info.F_Key[1],  "cldCLOAD", 80);     /* F2  */
	strncpy((char *)General_Info.F_Key[2],  "locLOCATE", 80);    /* F3  */
	strncpy((char *)General_Info.F_Key[3],  "lstLIST", 80);      /* F4  */
	strncpy((char *)General_Info.F_Key[4],  "runRUN\r", 80);     /* F5  */
	strncpy((char *)General_Info.F_Key[5],  "nul", 80);          /* F6  */
	strncpy((char *)General_Info.F_Key[6],  "dat?DATE$\r", 80);  /* SHIFT+F1 = F7  */
	strncpy((char *)General_Info.F_Key[7],  "csaCSAVE", 80);     /* SHIFT+F2 = F8  */
	strncpy((char *)General_Info.F_Key[8],  "prtPRINT", 80);     /* SHIFT+F3 = F9  */
	strncpy((char *)General_Info.F_Key[9],  "slpSLEEP", 80);     /* SHIFT+F4 = F10 */
	strncpy((char *)General_Info.F_Key[10], "cntCONT\r", 80);    /* SHIFT+F5 = F11 */
	strncpy((char *)General_Info.F_Key[11], "nul", 80);          /* SHIFT+F6 = F12 */

	General_Info.Curs_X       = 0;
	General_Info.Curs_Y       = 0;
	General_Info.Curseur      = 0;
	General_Info.Aff_Udk      = 0;
	General_Info.Rem_Canal    = 0;
	General_Info.Stick        = 0x30;
	General_Info.Strig        = 0xFF;
	General_Info.Strig1       = 0xFF;
	General_Info.Break        = 0;
  
	General_Info.size_point_x = 1;
	General_Info.size_point_y = 1;
}

void Reset_Xo7(void)
{
	fprintf(stderr, "RESET X07\n");

	memset((void*)RAM, 0xFF, Taille_Ram);
	memset((void*)&Port_FX, 0, sizeof(Port_FX));
	memset((void*)&Clavier, 0, sizeof(Clavier));

	if (Load_Ram_Temp() == RC_OK) {
		fprintf(stderr, "Reprise automatique de la RAM sauvegardée\n");
	} else {
		fprintf(stderr, "Pas de RAM sauvegardée, démarrage normal\n");
	}

	Tmp = 0;
	IT_T6834 = 0;
	Int_nsc800_BB = 0;
	Mode_K7 = 0;
	Power_Off = 0;

	ResetZ80(&Reg_Xo7);
	Reg_Xo7.IPeriod = 100;
	Reg_Xo7.Trace   = 0;
	Reg_Xo7.PC.W    = 0xC3C3;

	Init_Etat_Xo7();
	ClrScr();
}

void Power_Off_Xo7(void)
{
	if (Power_Off)
		return;

	fprintf(stderr, "POWER OFF X07\n");

	Power_Off = 1;

	Save_Ram_Temp();
	
	General_Info.Curseur = 0;
	ClrScr();
}

void Power_OnBreak_Xo7(void)
{
	if (Power_Off) {
		fprintf(stderr, "POWER ON X07\n");

		Power_Off = 0;
		IT_T6834 = 1;

		return;
	}

	fprintf(stderr, "ON/BREAK\n");
	General_Info.Break = 1;
}

/*----------------------------------------------------------------------*/
/* Gestion des K7 */
/*----------------------------------------------------------------------*/
void Send_to_K7 (PorT_FX *Port) {
	if ((Port->R.F4 & 0x09) == 0x09) {
		fprintf (stderr,"%02X ",Port->W.F7);
	}
}

void init_k7 (void)
{
	fprintf (stderr,"Init K7\n");
}

void Receive_from_K7 (PorT_FX *Port) {
	if (Presence_k7 && ((Port->R.F4 & 0x09) == 0x09)) {
		if (feof(Fichier_k7)) {
			rewind (Fichier_k7);
		}
		Port->R.F7  = fgetc (Fichier_k7);
		Port->R.F6 |= 0x02;
		IT_T6834 = 3;
	}
}

void Print (byte Cmd, PorT_FX *Port) {
	static byte Cpt_Bit=0;
	static byte Data=0;
	switch (Cmd) {
		case PRT_DATA:
			if (Port->R.F4 & MASK_PRT_DATA) 
				Data |= 1;
			Data <<= 1;
			Cpt_Bit ++;
			if (Cpt_Bit == 8) {
				fprintf (stderr,"Prt_data=0x%02X\n",Data);
				Cpt_Bit = 0;
				Data = 0;
			}
			break;
		case PRT_ACK: 
			break;
	}
}

/*----------------------------------------------------------------------*/
/*                 Affichage des registres du Z80                       */
/*----------------------------------------------------------------------*/
void DisplayReg(register Z80 *R)
{
 int value;
 char Flag[9];
 strcpy (Flag,"        ");
 if (R->AF.B.l & S_FLAG) Flag[0]='S';
 if (R->AF.B.l & Z_FLAG) Flag[1]='Z';
 if (R->AF.B.l & H_FLAG) Flag[3]='H';
 if (R->AF.B.l & V_FLAG) Flag[5]='V';
 if (R->AF.B.l & N_FLAG) Flag[6]='N';
 if (R->AF.B.l & C_FLAG) Flag[7]='C';
 fprintf (stderr,"AF :%04X BC :%04X DE :%04X HL :%04X\n",
           R->AF.W, R->BC.W, R->DE.W, R->HL.W);
 fprintf (stderr,"AF':%04X BC':%04X DE':%04X HL':%04X\n",
           R->AF1.W, R->BC1.W, R->DE1.W, R->HL1.W);
 fprintf (stderr,"PC :%04X SP :%04X IX :%04X IY :%04X\n",
           R->PC.W,R->SP.W,R->IX.W,R->IY.W);
 fprintf (stderr,"I  :%04X IFF:%04X %s\n",
           R->I,R->IFF,Flag);
 if ((R->PC.W >= 0xB000) && (R->PC.W <= 0xFFFF)) {
    value = ROM[R->PC.W - 0xB000];
    fprintf(stderr, "ROM[%04X] = %04X\n\n", R->PC.W, value);
 } else {
    value = RAM[R->PC.W];
    fprintf(stderr, "RAM[%04X] = %04X\n\n", R->PC.W, value);
 }
}

/*--------------------------------------------------------------------------*/
/* Ecriture des fonctions CPU Z80                                           */
/*--------------------------------------------------------------------------*/
/** RdZ80()/WrZ80() ******************************************/
/** These functions are called when access to RAM occurs.   **/
/** They allow to control memory access.                    **/
/************************************ TO BE WRITTEN BY USER **/
void WrZ80(register word Addr, register byte Value)
{
    if (Addr == 0x030B) {
        fprintf(stderr,
            "[ROM SOUND STATE] WR 030B=%02X depuis PC=%04X AF=%04X F4=%02X F6W=%02X F6R=%02X\n",
            Value,
            Reg_Xo7.PC.W,
            Reg_Xo7.AF.W,
            Port_FX.W.F4,
            Port_FX.W.F6,
            Port_FX.R.F6
        );
        fflush(stderr);
    }

    if ((Addr >= BEG_RAM) && (Addr < END_RAM)) {
        RAM[Addr] = Value;
    }
}

byte RdZ80(register word Addr)
{
    static word last_trace_pc = 0xFFFF;

    if (Addr == Reg_Xo7.PC.W) {
        if ((Addr >= 0xC3AC && Addr <= 0xC3C0) ||
            (Addr >= 0xDE9F && Addr <= 0xDEA6)) {

            if (last_trace_pc != Addr) {
                fprintf(stderr,
                    "[ROM SOUND EXEC] PC=%04X AF=%04X BC=%04X DE=%04X HL=%04X F4=%02X F6W=%02X F6R=%02X RAM030B=%02X\n",
                    Reg_Xo7.PC.W,
                    Reg_Xo7.AF.W,
                    Reg_Xo7.BC.W,
                    Reg_Xo7.DE.W,
                    Reg_Xo7.HL.W,
                    Port_FX.W.F4,
                    Port_FX.W.F6,
                    Port_FX.R.F6,
                    RAM[0x030B]
                );
                fflush(stderr);

                last_trace_pc = Addr;
            }
        }
    }

    if ((Addr >= 0xB000) && (Addr <= 0xFFFF))
        return ROM[Addr - 0xB000];

    if ((Addr >= 0xA000) && (Addr <= 0xAFFF)) {
        fprintf(stderr,
                "ROM TV absente: lecture Addr=%04X depuis PC=%04X SP=%04X HL=%04X\n",
                Addr, Reg_Xo7.PC.W, Reg_Xo7.SP.W, Reg_Xo7.HL.W);
        return 0xFF;
    }

    return RAM[Addr];
}

/** InZ80()/OutZ80() *****************************************/
/** Z80 emulation calls these functions to read/write from  **/
/** I/O ports. There can be 65536 I/O ports, but only first **/
/** 256 are usually used                                    **/
/************************************ TO BE WRITTEN BY USER **/
void OutZ80(register word Port,register byte Value) {
	Port &= 0xFF;
	switch (Port) {
		case 0xBB : /* Validation des interuptions du NSC800 */
			Int_nsc800_BB = Value;
			break;
		case 0xF0 : /* Controle des interruptions */
			Port_FX.W.F0 = Value;
			break;
		case 0xF1 : /* XBTR : Stockage des Informations pour CCU */
			Port_FX.W.F1 = Value;
			if (Port_FX.R.F0 == 0x00)
				Port_FX.R.F2 &= 0xFE;
			break;
		case 0xF2 : /* Controle de BAUDS (poids faible) */
			Port_FX.W.F2 = Value;
			break;
		case 0xF3 : /* Controle de BAUDS (poids fort) */ 
			Port_FX.W.F3 = Value;
			break;
		case 0xF4 : /* Modes */
		{
			byte old_f4 = Port_FX.W.F4;

			Port_FX.W.F4 = Value;
			Port_FX.R.F4 = Value;

			/*
			 * Vrai armement buzzer ROM :
			 * C3B1: OUT (F4),A
			 * Dans notre trace, le PC affiché est C3B3.
			 */
			if (Reg_Xo7.PC.W == 0xC3B3) {
				Sound_Armed = 1;

				fprintf(stderr,
					"[BEEP ARM REAL] PC=%04X F4 old=%02X new=%02X\n",
					Reg_Xo7.PC.W,
					old_f4,
					Value
				);
				fflush(stderr);
			}

			/*
			 * Trace utile pour voir les écritures F4 parasites.
			 */
			if (Reg_Xo7.PC.W == 0xC35F || Reg_Xo7.PC.W == 0xC3C0) {
				fprintf(stderr,
					"[F4 OTHER] PC=%04X F4 old=%02X new=%02X\n",
					Reg_Xo7.PC.W,
					old_f4,
					Value
				);
				fflush(stderr);
			}

			if ((Value & 0x0D) == 0x09)
				Mode_K7 = 1;
			else
				Mode_K7 = 0;

			if ((Mode_K7 == 1) && (Port_FX.W.F5 & 0x04))
				Receive_from_K7(&Port_FX);

			break;
		}		
		case 0xF5 : /* Interruptions (RESET) */
			Port_FX.W.F5 = Value;
			/* Reception d'un octet venant du T6834 *
			*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
			if (Value & 0x01)
				Receive_from_T6834 (LEC_T6834_ACK,&Port_FX);
			/* Envoie d'un octet a destination du T6834 *
			*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
			if (Value & 0x02)
				Send_to_T6834 (&Port_FX);
			/* Reception d'un octet EN PROVENANCE du lecteur de K7 *
			*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
			if (Value & 0x04)
				Receive_from_K7 (&Port_FX);
			/* Envoie d'un octet a destination du lecteur de K7 *
			*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
			if (Value & 0x08)
				Send_to_K7 (&Port_FX);
			/* Envoie d'un bit sur le port imprimante  *
			*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
			if (Value & 0x20)
				Print (PRT_DATA,&Port_FX);
			break;
        case 0xF6:
			if (Value == 0x10) {
				fprintf(stderr,
					"[BEEP F6] PC=%04X OUT F6,%02X armed=%d F4=%02X RAM030B=%02X\n",
					Reg_Xo7.PC.W,
					Value,
					Sound_Armed,
					Port_FX.W.F4,
					RAM[0x030B]
				);
				fflush(stderr);

				if (Sound_Armed && Reg_Xo7.PC.W == 0xDEA1) {
					Sound_Beep(1000, 50);
					Sound_Armed = 0;
				}

				Port_FX.W.F6 = Value & ~0x10;
				Port_FX.R.F6 = Value & ~0x10;
			} else {
				Port_FX.W.F6 = Value;
				Port_FX.R.F6 = Value;
			}
			break;
    	case 0xF7 : /* Données UART */
            Port_FX.W.F7 = Value;
            Port_FX.R.F7 = Value;
            break;
		default:
			fprintf (stderr,"Erreur de port ....");
			fprintf(stderr,
				"[OUT] PC=%04X PORT=%02X VALUE=%02X  F2=%02X F3=%02X F4=%02X F5=%02X\n",
				Reg_Xo7.PC.W,
				Port,
				Value,
				Port_FX.W.F2,
				Port_FX.W.F3,
				Port_FX.W.F4,
				Port_FX.W.F5
			);
			fflush(stderr);
			break;
	}	
	return;
}

byte InZ80(register word Port) {
	Port &= 0xFF;
	#if AFF_IN
	fprintf (stderr,"InZ80 (%04X) Out %02X\n",Reg_Xo7.PC.W,Port);
	#endif

	byte Value=0;
	switch (Port) {
		case 0xF0 : /* Controle des interruptions */
			Value = Port_FX.R.F0;
			break;
		case 0xF1 : /* XBRR : Stockage des Informations venant du CCU */
			Value = Port_FX.R.F1;
			/*Port_FX.R.F2 &= 0xFE;*/
			break;
		case 0xF2 : /* Flags sur l'etat du Canon XO7 */
			/*if (Port_FX.W.F5 & 0x08) Port_FX.R.F2 |=0x01;
			else                     Port_FX.R.F2 &=0xFE;*/
			if (Port_FX.W.F5 & 0x04)
				Port_FX.R.F2 |=0x02;
			else
				Port_FX.R.F2 &=0xFD;
			Value = Port_FX.R.F2 | 2;
			break;
		case 0xF3 : /* ~~~Vide~~~ */
			Value = Port_FX.R.F3;
			break;
		case 0xF4 : /* Status modes / buzzer */
            /*
             * Attention :
             * F4.W contient les bits écrits par la ROM.
             * Mais F4.R ne doit pas forcément retourner tous ces bits.
             *
             * La ROM teste F4 & 0x0C pour savoir si le buzzer est occupé.
             * Si on retourne CE, alors 0x0C reste actif et les BEEP suivants
             * sont bloqués.
             */
            Value = Port_FX.R.F4 & ~0x0C;

            if (Reg_Xo7.PC.W >= 0xC37B && Reg_Xo7.PC.W <= 0xC393) {
                fprintf(stderr,
                    "[IN F4 SOUND WAIT] PC=%04X R.F4=%02X returned=%02X W.F4=%02X\n",
                    Reg_Xo7.PC.W,
                    Port_FX.R.F4,
                    Value,
                    Port_FX.W.F4
                );
                fflush(stderr);
            }

            break;
		case 0xF5 : /* ~~~Vide~~~ */
			Value = Port_FX.R.F5;
			break;
        case 0xF6 : /* Status de l'UART */
            Value = Port_FX.R.F6 | 0x05;
            break;
		case 0xF7 : /* Données recu par l'UART */
			Value = Port_FX.R.F7;
			break;
	}
	return (Value);
}

/** PatchZ80() ***********************************************/
/** Z80 emulation calls this function when it encounters a  **/
/** special patch command (ED FE) provided for user needs.  **/
/** For example, it can be called to emulate BIOS calls,    **/
/** such as disk and tape access. Replace it with an empty  **/
/** macro for no patching.                                  **/
/************************************ TO BE WRITTEN BY USER **/
void PatchZ80(register Z80 *R) {
 fprintf (stderr,"PatchZ80\n");
 return;
}

/** LoopZ80() ************************************************/
/** Z80 emulation calls this function periodically to check **/
/** if the system hardware requires any interrupts. This    **/
/** function must return an address of the interrupt vector **/
/** (0x0038, 0x0066, etc.) or INT_NONE for no interrupt.    **/
/** Return INT_QUIT to exit the emulation loop.             **/
/************************************ TO BE WRITTEN BY USER **/

static unsigned long now_ms(void)
{
	struct timeval tv;

	gettimeofday(&tv, NULL);

	return (unsigned long)(tv.tv_sec * 1000UL) + (unsigned long)(tv.tv_usec / 1000UL);
}

word LoopZ80(register Z80 *R)
{
	static int Nb = 0;
	static int Lec_K7 = 0;
	int Event;

	Event = Voir_Xevent();

	if (Event == 27)
		return INT_QUIT;

	if (Power_Off) {
		while (Power_Off) {
			Event = Voir_Xevent();
			if (Event == 27)
				return INT_QUIT;

			usleep(20000);
		}
	return INT_NONE;
}
		
	if (Event > 0 && Event < 256) {
		Add_Key((byte)Event);
	}

	{
		static unsigned long last_cursor_ms = 0;
		unsigned long t = now_ms();

		if ((t - last_cursor_ms) >= 500) {
			Aff_Curseur();
			last_cursor_ms = t;
		}
	}

	if (R->IFF & 0x01) {
		if (Clavier.Nb_Key) {
			Clavier.Nb_Key--;

			Port_FX.R.F0 = 0x00;
			Port_FX.R.F1 = Clavier.Buff_Key[Clavier.Pt_Lec];
			/*			
			fprintf(stderr,
				"[KEY_TO_T6834] F1=0x%02X '%c' Nb=%d Pt_Lec=%d Pt_Ecr=%d IFF=0x%02X\n",
				Port_FX.R.F1,
				(Port_FX.R.F1 >= 32 && Port_FX.R.F1 <= 126) ? Port_FX.R.F1 : '.',
				Clavier.Nb_Key,
				Clavier.Pt_Lec,
				Clavier.Pt_Ecr,
				R->IFF);
			*/
			Port_FX.R.F2 |= 0x01;

			Clavier.Pt_Lec++;
			if (Clavier.Pt_Lec >= 20)
				Clavier.Pt_Lec = 0;

			IT_T6834 = 0;
			return IT_RST_A;
		}

		if (General_Info.Break == 1) {
			Port_FX.R.F0 = 0x80;
			Port_FX.R.F1 = 0x05;
			Port_FX.R.F2 |= 0x01;
			IT_T6834 = 0;
			General_Info.Break = 0;
			fprintf(stderr, "Break\n");
			return IT_RST_A;
		}

		if (IT_T6834) {
			switch (IT_T6834) {
				case 1:
					Receive_from_T6834(LEC_T6834, &Port_FX);
					IT_T6834 = 0;
					return IT_RST_A;

				case 2:
					Port_FX.R.F0 = 0x80;
					Port_FX.R.F1 = Nb;
					Port_FX.R.F2 |= 0x01;

					Nb++;
					if ((Nb == 4) || (Nb == 7))
						Nb++;
					if (Nb > 255)
						Nb = 0;

					IT_T6834 = 0;
					return IT_RST_A;

				case 3:
					if (Lec_K7 >= 100) {
						IT_T6834 = 0;
						Lec_K7 = 0;
					} else {
						Lec_K7++;
					}
					break;
			}
		}
	}

	return INT_NONE;
}

/*---------------------------------------------------------------------------*/
/*                                                                           */
/*                                                                           */
/*---------------------------------------------------------------------------*/
void Active_Debugger (int a) {
	fprintf (stderr,"Interruption!!!\n");
	Reg_Xo7.Trace=1;
	signal (a,Active_Debugger);
	DisplayReg(&Reg_Xo7);
	exit(0);
}

/*---------------------------------------------------------------------------*/
/*                                                                           */
/*                                                                           */
/*---------------------------------------------------------------------------*/
void Active_Int (int a) {
	static int Type = 2;
	fprintf (stderr,"Int T6834!!! 0X020F = %d   0X026D: %d %d\n",RAM[0x020f],RAM[0x026d],Type);
	signal (a,Active_Int);
	IT_T6834 = Type;
}
/*---------------------------------------------------------------------------*/
/*                                                                           */
/*                                                                           */
/*---------------------------------------------------------------------------*/
int Save_Ram_Temp(void)
{
	FILE *f;
	X07_State st;
	size_t n;

	memset(&st, 0, sizeof(st));
	memcpy(st.magic, X07_STATE_MAGIC, X07_STATE_MAGIC_LEN);

	st.taille_ram = Taille_Ram;

	st.Reg_Xo7_save       = Reg_Xo7;
	st.Port_FX_save       = Port_FX;
	st.General_Info_save  = General_Info;
	st.Clavier_save       = Clavier;

	st.Tmp_save           = Tmp;
	st.IT_T6834_save      = IT_T6834;
	st.Int_nsc800_BB_save = Int_nsc800_BB;
	st.Mode_K7_save       = Mode_K7;
	st.Power_Off_save     = 1;

	f = fopen(X07_STATE_FILE, "wb");
	if (!f) {
		perror("Save_Ram_Temp fopen");
		return RC_KO;
	}

	if (fwrite(&st, 1, sizeof(st), f) != sizeof(st)) {
		fclose(f);
		return RC_KO;
	}

	n = fwrite(RAM, 1, Taille_Ram, f);
	fclose(f);

	if (n != Taille_Ram) {
		fprintf(stderr,
		        "Save_Ram_Temp: RAM incomplète %lu/%lu octets\n",
		        (unsigned long)n,
		        (unsigned long)Taille_Ram);
		return RC_KO;
	}

	fprintf(stderr,
	        "Snapshot X07 sauvegardé dans %s RAM=%lu PC=%04X\n",
	        X07_STATE_FILE,
	        (unsigned long)Taille_Ram,
	        Reg_Xo7.PC.W);

	return RC_OK;
}

int Load_Ram_Temp(void)
{
	FILE *f;
	X07_State st;
	size_t n;

	f = fopen(X07_STATE_FILE, "rb");
	if (!f)
		return RC_KO;

	if (fread(&st, 1, sizeof(st), f) != sizeof(st)) {
		fclose(f);
		return RC_KO;
	}

	if (memcmp(st.magic, X07_STATE_MAGIC, X07_STATE_MAGIC_LEN) != 0) {
		fclose(f);
		fprintf(stderr, "Load_Ram_Temp: mauvais fichier snapshot\n");
		return RC_KO;
	}

	if (st.taille_ram != Taille_Ram) {
		fclose(f);
		fprintf(stderr,
		        "Load_Ram_Temp: taille RAM incompatible %u/%lu\n",
		        st.taille_ram,
		        (unsigned long)Taille_Ram);
		return RC_KO;
	}

	n = fread(RAM, 1, Taille_Ram, f);
	fclose(f);

	if (n != Taille_Ram) {
		fprintf(stderr,
		        "Load_Ram_Temp: lecture RAM incomplète %lu/%lu octets\n",
		        (unsigned long)n,
		        (unsigned long)Taille_Ram);
		return RC_KO;
	}

	Reg_Xo7       = st.Reg_Xo7_save;
	Port_FX       = st.Port_FX_save;
	General_Info  = st.General_Info_save;
	Clavier       = st.Clavier_save;

	Tmp           = st.Tmp_save;
	IT_T6834      = st.IT_T6834_save;
	Int_nsc800_BB = st.Int_nsc800_BB_save;
	Mode_K7       = st.Mode_K7_save;
	Power_Off     = 1;

	fprintf(stderr,
	        "Snapshot X07 restauré depuis %s RAM=%lu PC=%04X\n",
	        X07_STATE_FILE,
	        (unsigned long)Taille_Ram,
	        Reg_Xo7.PC.W);

	return RC_OK;
}
