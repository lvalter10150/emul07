#include <SDL2/SDL.h>
#include <math.h>
#include <stdio.h>

static SDL_AudioDeviceID audio_dev = 0;
static int sound_initialized = 0;

typedef struct {
    int freq_hz;
    int samples_left;
    double phase;
} BeepState;

static BeepState beep = {0, 0, 0.0};

static void audio_callback(void *userdata, Uint8 *stream, int len)
{
    Sint16 *buffer = (Sint16 *)stream;
    int samples = len / sizeof(Sint16);
    int sample_rate = 44100;

    for (int i = 0; i < samples; i++) {
        if (beep.samples_left > 0 && beep.freq_hz > 0) {
            double v = sin(beep.phase) * 3000.0;
            buffer[i] = (Sint16)v;

            beep.phase += 2.0 * M_PI * beep.freq_hz / sample_rate;
            if (beep.phase >= 2.0 * M_PI)
                beep.phase -= 2.0 * M_PI;

            beep.samples_left--;
        } else {
            buffer[i] = 0;
        }
    }
}

void Sound_Init(void)
{
    if (sound_initialized)
        return;

    if (SDL_InitSubSystem(SDL_INIT_AUDIO) != 0) {
        fprintf(stderr, "[SOUND] SDL audio init error: %s\n", SDL_GetError());
        return;
    }

    SDL_AudioSpec want;
    SDL_zero(want);

    want.freq = 44100;
    want.format = AUDIO_S16SYS;
    want.channels = 1;
    want.samples = 1024;
    want.callback = audio_callback;

    audio_dev = SDL_OpenAudioDevice(NULL, 0, &want, NULL, 0);
    if (!audio_dev) {
        fprintf(stderr, "[SOUND] SDL_OpenAudioDevice error: %s\n", SDL_GetError());
        return;
    }

    SDL_PauseAudioDevice(audio_dev, 0);
    sound_initialized = 1;

    fprintf(stderr, "[SOUND] initialized\n");
}

void Sound_Beep(int freq_hz, int duration_ms)
{
    static int n = 0;

    n++;
    fprintf(stderr, "[SOUND_BEEP #%d] freq=%d duration=%d\n",
        n,
        freq_hz,
        duration_ms
    );
    fflush(stderr);

    if (!sound_initialized)
        Sound_Init();

    if (!sound_initialized)
        return;

    SDL_LockAudioDevice(audio_dev);

    beep.freq_hz = freq_hz;
    beep.samples_left = 44100 * duration_ms / 1000;
    beep.phase = 0.0;

    SDL_UnlockAudioDevice(audio_dev);
}

void Sound_Close(void)
{
    if (audio_dev) {
        SDL_CloseAudioDevice(audio_dev);
        audio_dev = 0;
    }

    if (sound_initialized) {
        SDL_QuitSubSystem(SDL_INIT_AUDIO);
        sound_initialized = 0;
    }
}
