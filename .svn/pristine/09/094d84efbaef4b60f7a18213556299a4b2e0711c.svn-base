#include <SDL2/SDL.h>
#include <stdio.h>
#include <stdint.h>
#include <math.h>

#define SOUND_SAMPLE_RATE 44100
#define SOUND_VOLUME      5000

static SDL_AudioDeviceID audio_dev = 0;
static int sound_initialized = 0;

typedef struct {
    int active;
    int freq_hz;
    int samples_left;
    double phase;
} BuzzerState;

static BuzzerState buzzer = {0, 0, 0, 0.0};

static void audio_callback(void *userdata, Uint8 *stream, int len)
{
    Sint16 *buffer = (Sint16 *)stream;
    int samples = len / sizeof(Sint16);

    (void)userdata;

    for (int i = 0; i < samples; i++) {
        if (buzzer.active && buzzer.freq_hz > 0 && buzzer.samples_left > 0) {
            buffer[i] = (buzzer.phase < 0.5) ? SOUND_VOLUME : -SOUND_VOLUME;

            buzzer.phase += (double)buzzer.freq_hz / (double)SOUND_SAMPLE_RATE;
            if (buzzer.phase >= 1.0)
                buzzer.phase -= 1.0;

            buzzer.samples_left--;

            if (buzzer.samples_left <= 0) {
                buzzer.active = 0;
                buzzer.freq_hz = 0;
                buzzer.phase = 0.0;
            }
        } else {
            buffer[i] = 0;
        }
    }
}

void Sound_Init(void)
{
    SDL_AudioSpec want;

    if (sound_initialized)
        return;

    if (SDL_InitSubSystem(SDL_INIT_AUDIO) != 0) {
        fprintf(stderr, "[SOUND] SDL_InitSubSystem error: %s\n", SDL_GetError());
        return;
    }

    SDL_zero(want);
    want.freq = SOUND_SAMPLE_RATE;
    want.format = AUDIO_S16SYS;
    want.channels = 1;
    want.samples = 1024;
    want.callback = audio_callback;

    audio_dev = SDL_OpenAudioDevice(NULL, 0, &want, NULL, 0);
    if (!audio_dev) {
        fprintf(stderr, "[SOUND] SDL_OpenAudioDevice error: %s\n", SDL_GetError());
        return;
    }

    SDL_PauseAudioDevice(audio_dev, 0);
    sound_initialized = 1;

    fprintf(stderr, "[SOUND] initialized\n");
}

void Sound_Close(void)
{
    if (audio_dev) {
        SDL_CloseAudioDevice(audio_dev);
        audio_dev = 0;
    }

    if (sound_initialized) {
        SDL_QuitSubSystem(SDL_INIT_AUDIO);
        sound_initialized = 0;
    }
}

void Sound_Beep(int freq_hz, int duration_ms)
{
    if (freq_hz <= 0 || duration_ms <= 0)
        return;

    if (!sound_initialized)
        Sound_Init();

    if (!sound_initialized)
        return;

    SDL_LockAudioDevice(audio_dev);

    buzzer.active = 1;
    buzzer.freq_hz = freq_hz;
    buzzer.samples_left = SOUND_SAMPLE_RATE * duration_ms / 1000;
    buzzer.phase = 0.0;

    SDL_UnlockAudioDevice(audio_dev);

    fprintf(stderr, "[SOUND] beep %d Hz %d ms\n", freq_hz, duration_ms);
    fflush(stderr);
}

/*
 * Version provisoire X-07.
 * Pour l'instant, on ignore tone/length et on joue un beep fixe.
 * Cela permet de valider que le son refonctionne.
 */
void Sound_Beep_X07(unsigned char tone_x07, unsigned char length_x07)
{
    fprintf(stderr,
        "[SOUND X07 TEST] tone=%u length=%u -> beep fixe\n",
        tone_x07,
        length_x07
    );
    fflush(stderr);

    Sound_Beep(1000, 100);
}

int Sound_X07_Period_To_Freq(unsigned int period)
{
    int freq_hz;

    if (period == 0)
        return 0;
    /*
     * Conversion provisoire.
     *
     * D'après la trace :
     *   BEEP 10,n -> DE=0x002C = 44
     *
     * Si tone 10 correspond environ à 220 Hz,
     * alors constante ~= 44 * 220 = 9680.
     *
     * On ajustera avec les traces des autres notes.
     */
    freq_hz = 9680 / period;

    if (freq_hz < 40)
        freq_hz = 40;

    if (freq_hz > 8000)
        freq_hz = 8000;

    return freq_hz;
}
